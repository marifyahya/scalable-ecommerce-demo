version: '3.8'

services:
  api-gateway:
    ports:
      - "8000:8000"

  postgres:
    ports:
      - "5432:5432"

  cassandra:
    ports:
      - "9042:9042"

  redis:
    ports:
      - "6379:6379"

  rabbitmq:
    ports:
      - "5672:5672"
      - "15672:15672"

  opensearch:
    ports:
      - "9200:9200"

  prometheus:
    ports:
      - "9090:9090"

  loki:
    ports:
      - "3100:3100"

  grafana:
    ports:
      - "3000:3000"
